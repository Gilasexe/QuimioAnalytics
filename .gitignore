# ==========================================
# 1. ARQUIVOS DE DADOS (O mais importante!)
# ==========================================
# Evita subir os dados brutos e planilhas do IST Ambiental para o GitHub público
*.csv
*.xlsx
*.xls
data/
datasets/

# ==========================================
# 2. PYTHON E AMBIENTES VIRTUAIS
# ==========================================
# Ignora arquivos compilados que o Python gera sozinho
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignora as pastas de ambientes virtuais (cada um da equipe deve ter o seu local)
venv/
.venv/
env/
.env/

# ==========================================
# 3. JUPYTER NOTEBOOKS E FERRAMENTAS DE DADOS
# ==========================================
# Ignora os checkpoints automáticos do Jupyter
.ipynb_checkpoints/

# ==========================================
# 4. VARIÁVEIS DE AMBIENTE E SEGURANÇA
# ==========================================
# NUNCA suba senhas, credenciais de banco ou chaves de API
.env
.env.local
secrets.json

# ==========================================
# 5. CONFIGURAÇÕES DE IDES E SISTEMA OPERACIONAL
# ==========================================
# Configurações do VSCode e afins
.vscode/
.idea/

# Arquivos inúteis criados pelo Windows ou Mac
.DS_Store
Thumbs.db